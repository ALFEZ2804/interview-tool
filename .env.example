# Copia este archivo a .env y rellena con tus valores reales.
# .env está en .gitignore, no se subirá al repo.
# Un único archivo .env: lo lee Next.js (runtime) y el CLI de Prisma (al migrar).

# OpenAI — obtenida en https://platform.openai.com/api-keys
OPENAI_API_KEY=sk-proj-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# Modelo a usar. gpt-4o-mini es 20x más barato que gpt-4o y suficiente para esta tarea.
# Opciones probadas: gpt-4o-mini | gpt-4o | gpt-4.1-mini
OPENAI_MODEL=gpt-4o-mini

# Neon Postgres — cadena de conexión "pooled" del proyecto en https://console.neon.tech
DATABASE_URL="postgresql://usuario:password@ep-xxxx-pooler.region.aws.neon.tech/neondb?sslmode=require"

# Secreto compartido para la ingesta automática (POST /api/ingest desde el
# Apps Script que lee las transcripciones de Gemini). Genera uno aleatorio:
#   openssl rand -hex 32
INGEST_SECRET=pon-aqui-un-secreto-largo-y-aleatorio

# Google OAuth (ingesta automática desde Drive). Salen del JSON de credenciales
# OAuth (GCP -> APIs y servicios -> Credenciales -> ID de cliente OAuth, app web).
GOOGLE_CLIENT_ID=xxxxxxxx.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=GOCSPX-xxxxxxxxxxxxxxxxxxxx

# Clave para cifrar los refresh tokens en reposo. 32 bytes en hex (64 chars):
#   openssl rand -hex 32
TOKEN_ENC_KEY=pon-aqui-64-caracteres-hex

# El cron de ingesta se protege con INGEST_SECRET. Configura un pinger externo
# (p.ej. cron-job.org) que llame cada ~15 min a:
#   GET https://TU-APP/api/cron/ingest?key=<INGEST_SECRET>
