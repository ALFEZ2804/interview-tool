# Copia este archivo a .env.local y rellena con tus valores reales.
# .env.local está en .gitignore, no se subirá al repo.

# ──────────────────────────────────────────────
# AI — usa Gemini (recomendado) o OpenAI
# ──────────────────────────────────────────────

# Gemini — obtenida en https://aistudio.google.com/app/apikey
# Si está presente, se usa Gemini en lugar de OpenAI para analizar transcripts.
GEMINI_API_KEY=

# OpenAI — obtenida en https://platform.openai.com/api-keys
# Solo necesaria si no usas Gemini.
OPENAI_API_KEY=sk-proj-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
OPENAI_MODEL=gpt-4o-mini

# ──────────────────────────────────────────────
# Google OAuth2 — para leer transcripts de Gmail
# ──────────────────────────────────────────────
# Instrucciones:
# 1. Ve a https://console.cloud.google.com/ y crea un proyecto
# 2. Activa la API: "Gmail API"
# 3. Ve a "Credentials" → "Create Credentials" → "OAuth 2.0 Client ID"
# 4. Tipo: "Web application"
# 5. Authorized redirect URIs: http://localhost:3000/api/auth/google/callback
# 6. Copia Client ID y Client Secret aquí

GOOGLE_CLIENT_ID=xxxxxxxxxxxxxx.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=GOCSPX-xxxxxxxxxxxxxxxxxxxxxxxx
GOOGLE_REDIRECT_URI=http://localhost:3000/api/auth/google/callback

# ──────────────────────────────────────────────
# Sesión — secreto para cifrar la cookie de sesión
# ──────────────────────────────────────────────
# Mínimo 32 caracteres. Genera uno con: openssl rand -hex 32
SESSION_SECRET=cambia-esto-por-una-cadena-aleatoria-de-al-menos-32-caracteres
