# Copia este archivo a .env y rellena con tus valores reales.
# .env está en .gitignore, no se subirá al repo.
# Un único archivo .env: lo lee Next.js (runtime) y el CLI de Prisma (al migrar).

# OpenAI — obtenida en https://platform.openai.com/api-keys
OPENAI_API_KEY=sk-proj-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# Modelo a usar. gpt-4o-mini es 20x más barato que gpt-4o y suficiente para esta tarea.
# Opciones probadas: gpt-4o-mini | gpt-4o | gpt-4.1-mini
OPENAI_MODEL=gpt-4o-mini

# Neon Postgres — cadena de conexión "pooled" del proyecto en https://console.neon.tech
DATABASE_URL="postgresql://usuario:password@ep-xxxx-pooler.region.aws.neon.tech/neondb?sslmode=require"
